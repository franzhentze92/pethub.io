  "transactional_edge_functions": [
    {
      "id": "order_confirmation",
      "function": "send-order-confirmation",
      "template": "supabase/functions/send-order-confirmation/template.ts",
      "used_in_app": "Checkout — tras crear orden en Tienda",
      "priority": "critical",
      "note": "Resend vía edge function, no Supabase Auth"
    },
    {
      "id": "order_status_update",
      "function": "send-order-status-email",
      "template": "supabase/functions/send-order-confirmation/template.ts (buildOrderStatusHtml)",
      "used_in_app": "Proveedor / Reparto / Admin — al cambiar estado en Mis Órdenes",
      "triggers": ["processing", "shipped", "in_transit", "delivered", "completed", "cancelled"],
      "priority": "critical",
      "note": "Resend vía edge function"
    }
  ],
  "in_app_only_notifications": [
    { "module": "Nutrición / Recordatorios", "channel": "Push (VAPID)", "email": false },
    { "module": "Mis Órdenes", "channel": "Campana in-app + email solo al comprar", "email": "parcial" },
    { "module": "Adopción / Parejas / Chat", "channel": "Campana in-app", "email": false },
    { "module": "Suscripciones", "channel": "Cron renueva órdenes", "email": "pendiente — no implementado" }
  ]
